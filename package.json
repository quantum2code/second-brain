{
  "name": "second-brain",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "pnpm -r dev",
    "build": "pnpm -r build",
    "check-types": "pnpm -r check-types",
    "dev:web": "pnpm --filter web dev",
    "dev:server": "pnpm --filter server dev",
    "db:push": "pnpm --filter @second-brain/db db:push",
    "db:studio": "pnpm --filter @second-brain/db db:studio",
    "db:generate": "pnpm --filter @second-brain/db db:generate",
		"db:migrate": "pnpm --filter @second-brain/db db:migrate",
		"arcade:start": "sudo docker run -d --name arcadedb -p 2480:2480 -p 2424:2424   -e JAVA_OPTS='-Darcadedb.server.rootPassword=playwithdata'   arcadedata/arcadedb:latest",
		"arcade:stop": "sudo docker stop arcadedb"
  },
  "dependencies": {
    "@second-brain/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@second-brain/config": "workspace:*",
    "@types/node": "^22.13.14",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@11.5.1"
}
