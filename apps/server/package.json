{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "tsx watch src/index.ts",
    "dev:worker": "tsx watch src/workers/index.ts",
    "start": "node dist/index.mjs",
    "arcadedb:schema": "tsx src/scripts/arcadedb-schema.ts",
    "arcadedb:schema:reset": "tsx src/scripts/arcadedb-schema.ts --reset"
  },
  "dependencies": {
    "@google-cloud/local-auth": "2.1.0",
    "@langchain/core": "^1.1.48",
    "@langchain/google": "^0.1.12",
    "@langchain/google-genai": "^2.1.31",
    "@langchain/groq": "^1.2.1",
    "@langchain/langgraph": "^1.3.4",
    "@second-brain/db": "workspace:*",
    "@second-brain/env": "workspace:*",
    "@supabase/supabase-js": "^2.106.2",
    "axios": "^1.17.0",
    "bullmq": "^5.77.7",
    "cors": "^2.8.5",
    "discord.js": "^14.26.4",
    "dotenv": "catalog:",
    "express": "^5.1.0",
    "googleapis": "^105.0.0",
    "jsonwebtoken": "^9.0.3",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@second-brain/config": "workspace:*",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/node": "^22.13.14",
    "tsdown": "^0.21.9",
    "tsx": "^4.19.2",
    "typescript": "catalog:"
  },
  "trustedDependencies": [
    "supabase"
  ]
}
